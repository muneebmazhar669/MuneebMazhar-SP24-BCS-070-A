// ─── Models ───────────────────────────────────────────────────────────────────
class Msg {
  final String id;
  String text;
  final bool isUser;
  final DateTime time;
  final String? fileName;
  Msg({required this.id, required this.text,
    required this.isUser, required this.time, this.fileName});
  Map<String,dynamic> toJson() => {'id':id,'text':text,
    'isUser':isUser,'time':time.toIso8601String(),
    if (fileName != null) 'fileName': fileName};
  factory Msg.fromJson(Map<String,dynamic> j) => Msg(
      id: j['id'] as String? ?? '${DateTime.now().millisecondsSinceEpoch}',
      text: j['text'] as String, isUser: j['isUser'] as bool,
      time: DateTime.parse(j['time'] as String),
      fileName: j['fileName'] as String?);
}

class Chat {
  final String id;
  String title;
  final DateTime createdAt;
  List<Msg> msgs;
  Chat({required this.id, required this.title,
    required this.createdAt, required this.msgs});
  Map<String,dynamic> toJson() => {'id':id,'title':title,
    'createdAt':createdAt.toIso8601String(),
    'msgs':msgs.map((m)=>m.toJson()).toList()};
  factory Chat.fromJson(Map<String,dynamic> j) => Chat(
      id: j['id'] as String, title: j['title'] as String,
      createdAt: DateTime.parse(j['createdAt'] as String),
      msgs: (j['msgs'] as List? ?? [])
          .map((m)=>Msg.fromJson(m as Map<String,dynamic>)).toList());
  static String autoTitle(String s) =>
      s.length <= 36 ? s : '${s.substring(0,36)}...';
}

// ─── Storage ──────────────────────────────────────────────────────────────────
class Store {
  static const _k = 'bw_v6';
  static Future<List<Chat>> load() async {
    final p = await SharedPreferences.getInstance();
    final raw = p.getString(_k);
    if (raw == null) return [];
    return (jsonDecode(raw) as List)
        .map((e)=>Chat.fromJson(e as Map<String,dynamic>)).toList();
  }
  static Future<void> save(List<Chat> c) async {
    final p = await SharedPreferences.getInstance();
    await p.setString(_k, jsonEncode(c.map((x)=>x.toJson()).toList()));
  }
}


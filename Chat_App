// ─── Screen ───────────────────────────────────────────────────────────────────
class _Screen extends StatefulWidget {
  const _Screen();
  @override State<_Screen> createState() => _ScreenState();
}

class _ScreenState extends State<_Screen>
    with SingleTickerProviderStateMixin {
  List<Chat> _chats = [];
  Chat? _cur;
  final _in  = TextEditingController();
  final _sc  = ScrollController();
  final _fn  = FocusNode();
  bool _busy        = false;
  bool _sbExpanded  = true;
  bool _drawerOpen  = false;
  bool _showAttach  = false;

  String? _pendingFileName;
  String? _pendingFileType;

  late AnimationController _sbAnim;
  late Animation<double> _sbW;
  static const _sbFull = 240.0;
  static const _sbMin  = 56.0;

  @override
  void initState() {
    super.initState();
    _sbAnim = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 200));
    _sbW = Tween<double>(begin: _sbMin, end: _sbFull).animate(
        CurvedAnimation(parent: _sbAnim, curve: Curves.easeInOut));
    _sbAnim.forward();
    _boot();
  }

  Future<void> _boot() async {
    final c = await Store.load();
    setState(() { _chats = c; _cur = c.isNotEmpty ? c.first : _make(); });
  }

  Chat _make() {
    final c = Chat(id:'${DateTime.now().millisecondsSinceEpoch}',
        title:'New Chat', createdAt:DateTime.now(), msgs:[]);
    _chats.insert(0, c);
    Store.save(_chats);
    return c;
  }

  void _toggleSb() {
    setState(() => _sbExpanded = !_sbExpanded);
    _sbExpanded ? _sbAnim.forward() : _sbAnim.reverse();
  }

  void _new() => setState(() {
    _cur = _make();
    _pendingFileName = null;
    _drawerOpen = false;
  });

  void _open(Chat c) => setState(() {
    _cur = c;
    _drawerOpen = false;
  });

  Future<void> _del(Chat c) async {
    setState(() {
      _chats.remove(c);
      if (_cur?.id == c.id)
        _cur = _chats.isNotEmpty ? _chats.first : _make();
    });
    await Store.save(_chats);
  }

  Future<void> _pickImage() async {
    setState(() => _showAttach = false);
    final result = await FilePicker.platform.pickFiles(
        type: FileType.image, allowMultiple: false);
    if (result != null && result.files.isNotEmpty) {
      setState(() {
        _pendingFileName = result.files.first.name;
        _pendingFileType = 'image';
      });
    }
  }

  Future<void> _pickPdf() async {
    setState(() => _showAttach = false);
    final result = await FilePicker.platform.pickFiles(
      type: FileType.custom,
      allowedExtensions: ['pdf'],
      allowMultiple: false,
    );
    if (result != null && result.files.isNotEmpty) {
      setState(() {
        _pendingFileName = result.files.first.name;
        _pendingFileType = 'pdf';
      });
    }
  }

  Future<void> _pickAnyFile() async {
    setState(() => _showAttach = false);
    final result = await FilePicker.platform.pickFiles(
        type: FileType.any, allowMultiple: false);
    if (result != null && result.files.isNotEmpty) {
      setState(() {
        _pendingFileName = result.files.first.name;
        _pendingFileType = 'file';
      });
    }
  }

  void _removePending() => setState(() {
    _pendingFileName = null;
    _pendingFileType = null;
  });

  Future<void> _send() async {
    final t = _in.text.trim();
    final hasFile = _pendingFileName != null;
    if (t.isEmpty && !hasFile) return;
    if (_busy || _cur == null) return;

    final msgText = t.isNotEmpty ? t : '📎 Attached: $_pendingFileName';
    final fileName = _pendingFileName;

    _in.clear();
    setState(() {
      _showAttach = false;
      _pendingFileName = null;
      _pendingFileType = null;
    });
    _fn.requestFocus();

    if (_cur!.msgs.isEmpty)
      setState(() => _cur!.title = Chat.autoTitle(msgText));

    setState(() {
      _cur!.msgs.add(Msg(
          id:'${DateTime.now().millisecondsSinceEpoch}',
          text: msgText, isUser:true,
          time:DateTime.now(), fileName: fileName));
      _busy = true;
    });
    _down(); await Store.save(_chats);

    try {
      final r = await _api(_cur!.msgs);
      setState(() => _cur!.msgs.add(Msg(
          id:'${DateTime.now().millisecondsSinceEpoch}',
          text:r, isUser:false, time:DateTime.now())));
      await Store.save(_chats);
    } catch(e) {
      setState(() => _cur!.msgs.add(Msg(
          id:'${DateTime.now().millisecondsSinceEpoch}',
          text:'⚠️ ${e.toString()}', isUser:false, time:DateTime.now())));
    } finally { setState(() => _busy = false); _down(); }
  }

  Future<void> _edit(Msg m) async {
    final ctrl = TextEditingController(text: m.text);
    final ok = await showDialog<bool>(
      context: context,
      barrierColor: Colors.black.withOpacity(0.4),
      builder: (_) => _EditDlg(ctrl: ctrl),
    );
    if (ok != true) return;
    final nt = ctrl.text.trim();
    if (nt.isEmpty) return;
    final idx = _cur!.msgs.indexOf(m);
    if (idx < 0) return;
    setState(() {
      m.text = nt;
      _cur!.msgs.removeRange(idx + 1, _cur!.msgs.length);
      _busy = true;
    });
    _down(); await Store.save(_chats);
    try {
      final r = await _api(_cur!.msgs);
      setState(() => _cur!.msgs.add(Msg(
          id:'${DateTime.now().millisecondsSinceEpoch}',
          text:r, isUser:false, time:DateTime.now())));
      await Store.save(_chats);
    } catch(e) {
      setState(() => _cur!.msgs.add(Msg(
          id:'${DateTime.now().millisecondsSinceEpoch}',
          text:'⚠️ ${e.toString()}', isUser:false, time:DateTime.now())));
    } finally { setState(() => _busy = false); _down(); }
  }

  Future<String> _api(List<Msg> msgs) async {
    final res = await http.post(Uri.parse(kProxyUrl),
        headers: {'Content-Type':'application/json'},
        body: jsonEncode({'messages': msgs.map((m)=>
        {'role':m.isUser?'user':'assistant','content':m.text}).toList()}));
    if (res.statusCode == 200)
      return (jsonDecode(res.body)['content'] as List)[0]['text'] as String;
    throw Exception((jsonDecode(res.body)['error']?.toString()) ?? 'Error');
  }

  void _down() => WidgetsBinding.instance.addPostFrameCallback((_) {
    if (_sc.hasClients) _sc.animateTo(_sc.position.maxScrollExtent,
        duration:const Duration(milliseconds:300), curve:Curves.easeOut);
  });

  void _copy(String t) {
    Clipboard.setData(ClipboardData(text:t));
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: const Text('Copied to clipboard'),
      backgroundColor: cAccent,
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(r8)),
      duration: const Duration(seconds: 2),
    ));
  }

  String _rel(DateTime dt) {
    final d = DateTime.now().difference(dt).inDays;
    if (d==0) return 'Today'; if (d==1) return 'Yesterday';
    if (d<7) return '${d}d ago';
    return '${dt.day}/${dt.month}/${dt.year}';
  }

  IconData _fileIcon(String? type) {
    if (type == 'image') return Icons.image_outlined;
    if (type == 'pdf')   return Icons.picture_as_pdf_outlined;
    return Icons.attach_file_outlined;
  }

  @override
  void dispose() {
    _in.dispose(); _sc.dispose(); _fn.dispose();
    _sbAnim.dispose(); super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final top    = MediaQuery.of(context).padding.top;
    final bot    = MediaQuery.of(context).padding.bottom;
    final isWide = MediaQuery.of(context).size.width > 600;

    return Scaffold(
      backgroundColor: cBg,
      body: Stack(
        children: [
          Column(children: [
            _topBar(top),
            Expanded(child: Row(children: [
              if (isWide) _sidebar(),
              Expanded(child: Column(children: [
                Expanded(child: _msgList()),
                if (_busy) _typing(),
                if (_showAttach) _attachPanel(),
                if (_pendingFileName != null) _filePreviewBar(),
                _inputBar(bot),

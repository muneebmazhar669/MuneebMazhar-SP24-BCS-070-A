          Row(
            mainAxisAlignment: u ? MainAxisAlignment.end : MainAxisAlignment.start,
            crossAxisAlignment: CrossAxisAlignment.end,
            children: [
              if (!u) ...[_AiBadge(), const SizedBox(width:s8)],
              Flexible(
                child: Column(
                  crossAxisAlignment: u ? CrossAxisAlignment.end : CrossAxisAlignment.start,
                  children: [
                    if (msg.fileName != null)
                      Container(
                        margin: const EdgeInsets.only(bottom: s6),
                        padding: const EdgeInsets.symmetric(horizontal: s12, vertical: s8),
                        decoration: BoxDecoration(
                          color: u ? Colors.white.withOpacity(0.15) : cSurfaceAlt,
                          borderRadius: BorderRadius.circular(r10),
                          border: Border.all(

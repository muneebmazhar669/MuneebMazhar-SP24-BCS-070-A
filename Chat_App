            ])),
          ]),

          if (!isWide && _drawerOpen)
            GestureDetector(
              onTap: () => setState(() => _drawerOpen = false),
              child: Container(color: Colors.black.withOpacity(0.45)),
            ),

          if (!isWide)
            AnimatedPositioned(
              duration: const Duration(milliseconds: 220),

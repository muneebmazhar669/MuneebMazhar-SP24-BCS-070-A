  Widget _entryBox(Color c, List<Widget> fields, VoidCallback del) =>
      Container(
        margin: const EdgeInsets.only(bottom: 10),
        padding: const EdgeInsets.all(10),
        decoration: BoxDecoration(color: c.withOpacity(0.04),
            borderRadius: BorderRadius.circular(10),
            border: Border.all(color: c.withOpacity(0.2))),
        child: Column(children: [
          ...fields,
          Align(alignment: Alignment.centerRight,
              child: TextButton.icon(onPressed: del,
                  icon: const Icon(Icons.delete_outline_rounded, color: Colors.red, size: 15),
                  label: const Text('Remove',
                      style: TextStyle(color: Colors.red, fontSize: 12)))),
        ]),
      );

  Widget _addBtn(String label, Color color, VoidCallback fn) =>
      OutlinedButton.icon(
        onPressed: fn,
        icon: Icon(Icons.add_circle_outline_rounded, color: color, size: 17),
        label: Text(label, style: TextStyle(color: color, fontSize: 13)),
        style: OutlinedButton.styleFrom(
          side: BorderSide(color: color.withOpacity(0.4)),
          shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(10)),
          padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),

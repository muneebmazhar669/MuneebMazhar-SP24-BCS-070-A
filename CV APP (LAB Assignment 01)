enum CVMode { professional, hobby }

class CVMainPage extends StatefulWidget {
  final ProfessionalCV initialProf;
  final HobbyCV initialHobby;
  const CVMainPage({super.key, required this.initialProf, required this.initialHobby});

  @override
  State<CVMainPage> createState() => _CVMainPageState();
}

class _CVMainPageState extends State<CVMainPage>
    with SingleTickerProviderStateMixin {
  CVMode _mode = CVMode.professional;
  late AnimationController _animCtrl;
  late Animation<double> _fadeAnim;
  late ProfessionalCV _profCV;
  late HobbyCV _hobbyCV;

  @override
  void initState() {
    super.initState();
    _profCV  = widget.initialProf;
    _hobbyCV = widget.initialHobby;
    _animCtrl = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 280));
    _fadeAnim = CurvedAnimation(parent: _animCtrl, curve: Curves.easeInOut);
    _animCtrl.forward();
  }

  @override
  void dispose() { _animCtrl.dispose(); super.dispose(); }

  void _switchMode(CVMode m) {
    if (_mode == m) return;
    _animCtrl.reverse().then((_) {
      setState(() => _mode = m);
      _animCtrl.forward();
    });
  }

  bool get _isPro => _mode == CVMode.professional;

  Color get _appBarColor   => _isPro ? kGrayDark : kSkyDark;
  Color get _statsBarColor => _isPro ? kGrayMid  : kSkyMid;
  Color get _divColor      => _isPro ? kGrayDiv  : kSkyDiv;

  String get _statMid      => _isPro ? '${_profCV.keySkills.length}'      : '${_hobbyCV.hobbies.length}';
  String get _statMidLbl   => _isPro ? 'Skills'                           : 'Hobbies';
  String get _statRight    => _isPro ? '${_profCV.workExperience.length}' : '${_hobbyCV.achievements.length}';
  String get _statRightLbl => _isPro ? 'Jobs'                             : 'Awards';

  Future<void> _openBuildCV() async {
    final res = await Navigator.push<Map<String, dynamic>>(
      context,
      MaterialPageRoute(builder: (_) => BuildCVPage(
          initialProf: _profCV, initialHobby: _hobbyCV)),
    );
    if (res != null) setState(() {
      if (res['profCV']  != null) _profCV  = res['profCV'];
      if (res['hobbyCV'] != null) _hobbyCV = res['hobbyCV'];
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: kBg,
      appBar: AppBar(
        backgroundColor: _appBarColor,
        elevation: 0,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios_rounded, color: Colors.white),
          onPressed: () => Navigator.pop(context),
        ),
        title: Text(_isPro ? 'Professional CV' : 'Hobby CV',
            style: const TextStyle(
                color: Colors.white, fontWeight: FontWeight.bold, fontSize: 20)),
        centerTitle: true,
        actions: [
          GestureDetector(
            onTap: _openBuildCV,
            child: Container(
              margin: const EdgeInsets.only(right: 12),
              padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 6),
              decoration: BoxDecoration(
                  color: Colors.white.withOpacity(0.15),
                  borderRadius: BorderRadius.circular(10)),
              child: const Row(children: [
                Icon(Icons.edit_note_rounded, color: Colors.white, size: 15),
                SizedBox(width: 4),
                Text('Build', style: TextStyle(
                    color: Colors.white, fontWeight: FontWeight.bold, fontSize: 13)),
              ]),
            ),
          ),
        ],
        bottom: PreferredSize(
          preferredSize: const Size.fromHeight(68),
          child: Container(
            color: _statsBarColor,
            padding: const EdgeInsets.symmetric(vertical: 10),
            child: Row(children: [
              _statCol(_isPro
                  ? _profCV.name.split(' ').first
                  : _hobbyCV.name.split(' ').first, 'Name'),
              Container(width: 1, height: 34, color: _divColor),
              _statCol(_statMid, _statMidLbl),
              Container(width: 1, height: 34, color: _divColor),
              _statCol(_statRight, _statRightLbl),
            ]),
          ),
        ),
      ),
      body: Column(children: [
        _buildToggleBar(),
        Expanded(
          child: FadeTransition(
            opacity: _fadeAnim,
            child: _isPro
                ? ProfessionalCVView(data: _profCV)
                : HobbyCVView(data: _hobbyCV),
          ),
        ),
      ]),
      floatingActionButton: FloatingActionButton.extended(
        onPressed: _openBuildCV,
        backgroundColor: _appBarColor,
        elevation: 4,
        icon: const Icon(Icons.construction_rounded, color: Colors.white),
        label: const Text('Build CV',
            style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold)),
      ),
    );
  }

  Widget _buildToggleBar() {
    return Container(
      color: kBg,
      padding: const EdgeInsets.fromLTRB(16, 12, 16, 4),
      child: Container(
        height: 44,
        decoration: BoxDecoration(
          color: _appBarColor.withOpacity(0.10),
          borderRadius: BorderRadius.circular(30),
        ),
        child: Row(children: [
          _toggleBtn('💼  Professional', CVMode.professional),
          _toggleBtn('🎨  Hobby',        CVMode.hobby),
        ]),
      ),
    );
  }

  Widget _toggleBtn(String label, CVMode m) {
    final active = _mode == m;
    // each button always shows its own mode colour
    final btnColor = m == CVMode.professional ? kGrayDark : kSkyDark;
    return Expanded(
      child: GestureDetector(
        onTap: () => _switchMode(m),
        child: AnimatedContainer(
          duration: const Duration(milliseconds: 250),
          margin: const EdgeInsets.all(4),
          decoration: BoxDecoration(
            color: active ? btnColor : Colors.transparent,
            borderRadius: BorderRadius.circular(26),
          ),
          alignment: Alignment.center,
          child: Text(label,
              style: TextStyle(
                color: active ? Colors.white : btnColor,
                fontWeight: FontWeight.w700,
                fontSize: 14,
              )),
        ),
      ),
    );
  }

  static Widget _statCol(String val, String label) {
    return Expanded(child: Column(children: [
      Text(val, style: const TextStyle(
          color: Colors.white, fontSize: 18, fontWeight: FontWeight.w900)),
      Text(label, style: const TextStyle(color: kTextMuted, fontSize: 11)),
    ]));
  }
}


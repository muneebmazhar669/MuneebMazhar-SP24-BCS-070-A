class Education {
  String degree, institution, year;
  Education({required this.degree, required this.institution, required this.year});
}

class WorkExperience {
  String role, company, duration, description;
  WorkExperience({required this.role, required this.company, required this.duration, required this.description});
}

class ProjectItem {
  String title, description, tech;
  ProjectItem({required this.title, required this.description, required this.tech});
}

class CertItem {
  String name, issuer, year;
  CertItem({required this.name, required this.issuer, required this.year});
}

class Reference {
  String name, role, contact;
  Reference({required this.name, required this.role, required this.contact});
}

class ProfessionalCV {
  String name, jobTitle, phone, email, linkedin, portfolio, city, country, summary;
  List<String> keySkills, languages, volunteerWork, interests;
  List<WorkExperience> workExperience;
  List<ProjectItem> projects;
  List<Education> education;
  List<CertItem> certifications;
  List<Reference> references;

  ProfessionalCV({
    required this.name, required this.jobTitle, required this.phone,
    required this.email, required this.linkedin, required this.portfolio,
    required this.city, required this.country, required this.summary,
    required this.keySkills, required this.languages, required this.volunteerWork,
    required this.interests, required this.workExperience, required this.projects,
    required this.education, required this.certifications, required this.references,
  });
}

class HobbyProjectItem {
  String title, description;
  HobbyProjectItem({required this.title, required this.description});
}

class AchievementItem {
  String title, detail;
  AchievementItem({required this.title, required this.detail});
}

class CommunityItem {
  String role, org, detail;
  CommunityItem({required this.role, required this.org, required this.detail});
}

class HobbyCV {
  String name, email, phone, social, portfolio, personalProfile;
  List<String> hobbies, skills, additionalInterests;
  List<HobbyProjectItem> personalProjects;
  List<AchievementItem> achievements;
  List<CommunityItem> communityInvolvement;
  List<Education> education;

  HobbyCV({
    required this.name, required this.email, required this.phone,
    required this.social, required this.portfolio, required this.personalProfile,
    required this.hobbies, required this.skills, required this.additionalInterests,
    required this.personalProjects, required this.achievements,
    required this.communityInvolvement, required this.education,
  });
}


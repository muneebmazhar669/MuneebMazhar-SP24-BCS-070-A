// ═══════════════════════════════════════════════════════════════
//  BUILD CV PAGE
//  — Shared fields: name, email, phone are synced across both tabs
//  — All inputs start blank (except when synced from other tab)
// ═══════════════════════════════════════════════════════════════

class BuildCVPage extends StatefulWidget {
  final ProfessionalCV initialProf;
  final HobbyCV initialHobby;
  const BuildCVPage({super.key, required this.initialProf, required this.initialHobby});

  @override
  State<BuildCVPage> createState() => _BuildCVPageState();
}

class _BuildCVPageState extends State<BuildCVPage>
    with SingleTickerProviderStateMixin {
  late TabController _tab;

  // ── SHARED fields (synced between both tabs) ──
  final _sharedName  = TextEditingController();
  final _sharedEmail = TextEditingController();
  final _sharedPhone = TextEditingController();

  // ── Professional-only blank controllers ──
  final _pJobTitle  = TextEditingController();
  final _pLinkedin  = TextEditingController();
  final _pPortfolio = TextEditingController();
  final _pCity      = TextEditingController();
  final _pCountry   = TextEditingController();
  final _pSummary   = TextEditingController();
  final _pSkills    = TextEditingController();
  final _pLang      = TextEditingController();
  final _pVol       = TextEditingController();
  final _pInt       = TextEditingController();
  final List<Map<String, TextEditingController>> _work  = [];
  final List<Map<String, TextEditingController>> _proj  = [];
  final List<Map<String, TextEditingController>> _edu   = [];
  final List<Map<String, TextEditingController>> _cert  = [];
  final List<Map<String, TextEditingController>> _ref   = [];

  // ── Hobby-only blank controllers ──
  final _hSocial    = TextEditingController();
  final _hPortfolio = TextEditingController();
  final _hProfile   = TextEditingController();
  final _hHobbies   = TextEditingController();
  final _hSkills    = TextEditingController();
  final _hAdd       = TextEditingController();
  final List<Map<String, TextEditingController>> _hProj  = [];
  final List<Map<String, TextEditingController>> _hAch   = [];
  final List<Map<String, TextEditingController>> _hComm  = [];
  final List<Map<String, TextEditingController>> _hEdu   = [];

  // Track which tab we are on to sync shared fields on tab switch
  int _currentTab = 0;

  @override
  void initState() {
    super.initState();
    _tab = TabController(length: 2, vsync: this);
    _tab.addListener(_onTabChanged);
  }

  void _onTabChanged() {
    // Nothing extra needed — shared controllers are directly bound to both tabs
    if (!_tab.indexIsChanging) setState(() => _currentTab = _tab.index);
  }

  @override
  void dispose() {
    _tab.removeListener(_onTabChanged);
    _tab.dispose();
    for (var c in [
      _sharedName, _sharedEmail, _sharedPhone,
      _pJobTitle, _pLinkedin, _pPortfolio, _pCity, _pCountry,
      _pSummary, _pSkills, _pLang, _pVol, _pInt,
      _hSocial, _hPortfolio, _hProfile, _hHobbies, _hSkills, _hAdd,
    ]) { c.dispose(); }
    for (var m in [..._work,..._proj,..._edu,..._cert,..._ref,
      ..._hProj,..._hAch,..._hComm,..._hEdu]) {
      m.values.forEach((c) => c.dispose());
    }
    super.dispose();
  }

  void _save() {
    final newProf = ProfessionalCV(
      name: _sharedName.text,   // ← shared
      email: _sharedEmail.text, // ← shared
      phone: _sharedPhone.text, // ← shared
      jobTitle: _pJobTitle.text, linkedin: _pLinkedin.text,
      portfolio: _pPortfolio.text, city: _pCity.text, country: _pCountry.text,
      summary: _pSummary.text,
      keySkills: _pSkills.text.split(',').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      workExperience: _work.map((m) => WorkExperience(
          role: m['role']!.text, company: m['company']!.text,
          duration: m['duration']!.text, description: m['desc']!.text)).toList(),
      projects: _proj.map((m) => ProjectItem(
          title: m['title']!.text, description: m['desc']!.text,
          tech: m['tech']!.text)).toList(),
      education: _edu.map((m) => Education(
          degree: m['degree']!.text, institution: m['inst']!.text,
          year: m['year']!.text)).toList(),
      certifications: _cert.map((m) => CertItem(
          name: m['name']!.text, issuer: m['issuer']!.text,
          year: m['year']!.text)).toList(),
      languages: _pLang.text.split(',').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      volunteerWork: _pVol.text.split('\n').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      interests: _pInt.text.split(',').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      references: _ref.map((m) => Reference(
          name: m['name']!.text, role: m['role']!.text,
          contact: m['contact']!.text)).toList(),
    );

    final newHobby = HobbyCV(
      name: _sharedName.text,   // ← shared
      email: _sharedEmail.text, // ← shared
      phone: _sharedPhone.text, // ← shared
      social: _hSocial.text, portfolio: _hPortfolio.text,
      personalProfile: _hProfile.text,
      hobbies: _hHobbies.text.split('\n').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      personalProjects: _hProj.map((m) => HobbyProjectItem(
          title: m['title']!.text, description: m['desc']!.text)).toList(),
      skills: _hSkills.text.split('\n').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
      achievements: _hAch.map((m) => AchievementItem(
          title: m['title']!.text, detail: m['detail']!.text)).toList(),
      communityInvolvement: _hComm.map((m) => CommunityItem(
          role: m['role']!.text, org: m['org']!.text,
          detail: m['detail']!.text)).toList(),
      education: _hEdu.map((m) => Education(
          degree: m['degree']!.text, institution: m['inst']!.text,
          year: m['year']!.text)).toList(),
      additionalInterests: _hAdd.text.split('\n').map((s) => s.trim()).where((s) => s.isNotEmpty).toList(),
    );

    Navigator.pop(context, {'profCV': newProf, 'hobbyCV': newHobby});
  }

  // ── Input decoration helpers ──────────────────────────────
  InputDecoration _fdGray(String label, {String? hint}) => _deco(label, kGrayDark, hint: hint);
  InputDecoration _fdSky(String label,  {String? hint}) => _deco(label, kSkyDark,  hint: hint);
  InputDecoration _fdShared(String label, {String? hint}) {
    // shared fields use the colour of the currently active tab
    return _currentTab == 0
        ? _fdGray(label, hint: hint)
        : _fdSky(label, hint: hint);
  }

  InputDecoration _deco(String label, Color focusColor, {String? hint}) =>
      InputDecoration(
        labelText: label, hintText: hint,
        labelStyle: const TextStyle(fontSize: 13),
        isDense: true,
        contentPadding: const EdgeInsets.symmetric(horizontal: 12, vertical: 10),
        border: OutlineInputBorder(borderRadius: BorderRadius.circular(10)),
        focusedBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(10),
            borderSide: BorderSide(color: focusColor, width: 2)),
        enabledBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(10),
            borderSide: BorderSide(color: Colors.grey.shade300)),
      );


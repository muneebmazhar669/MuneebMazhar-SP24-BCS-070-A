// ════════════════════════════════════════════════════════════
//  ANIMATED DOTS (used inside TimeoutDialog)
// ════════════════════════════════════════════════════════════
class _LoadingDots extends StatefulWidget {
  const _LoadingDots();

  @override
  State<_LoadingDots> createState() => _LoadingDotsState();
}

class _LoadingDotsState extends State<_LoadingDots>
    with SingleTickerProviderStateMixin {
  late final AnimationController _ctrl;

  @override
  void initState() {
    super.initState();
    _ctrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 900),
    )..repeat();
  }

  @override
  void dispose() {
    _ctrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: _ctrl,
      builder: (_, __) {
        return Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: List.generate(3, (i) {
            // stagger each dot
            final phase = (_ctrl.value - i * 0.2).clamp(0.0, 1.0);
            final scale = 0.6 + 0.4 * (phase < 0.5 ? phase * 2 : (1 - phase) * 2);
            return Padding(
              padding: const EdgeInsets.symmetric(horizontal: 3),
              child: Transform.scale(
                scale: scale,
                child: Container(
                  width: 8,
                  height: 8,
                  decoration: const BoxDecoration(
                    shape: BoxShape.circle,
                    color: kTimerLow,
                  ),
                ),
              ),
            );
          }),
        );
      },
    );
  }
}

// ════════════════════════════════════════════════════════════
//  RESULT SCREEN
// ════════════════════════════════════════════════════════════
class ResultScreen extends StatelessWidget {
  final List<int?> answers;
  const ResultScreen({super.key, required this.answers});

  int get _score => answers
      .asMap()
      .entries
      .where((e) => e.value == kQuestions[e.key].answerIndex)
      .length;

  @override
  Widget build(BuildContext context) {
    final int    score = _score;
    final int    total = kQuestions.length;
    final double pct   = score / total;

    final String   grade;
    final Color    gradeColor;
    final IconData gradeIcon;

    if (pct == 1.0) {
      grade = 'Perfect Score!';  gradeColor = kCorrect;
      gradeIcon = Icons.workspace_premium_rounded;
    } else if (pct >= 0.75) {
      grade = 'Excellent Work!'; gradeColor = kCorrect;
      gradeIcon = Icons.emoji_events_rounded;
    } else if (pct >= 0.5) {
      grade = 'Good Effort!';    gradeColor = kAccent;
      gradeIcon = Icons.thumb_up_alt_rounded;
    } else {
      grade = 'Keep Studying!';  gradeColor = kWrong;
      gradeIcon = Icons.menu_book_rounded;
    }

    return Scaffold(
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(kPad),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              GestureDetector(
                onTap: () =>
                    Navigator.popUntil(context, (r) => r.isFirst),
                child: const _BackChip(),
              ),
              const SizedBox(height: 28),
              _ResultHero(
                score:      score,
                total:      total,
                grade:      grade,
                gradeColor: gradeColor,
                gradeIcon:  gradeIcon,
              ),
              const SizedBox(height: 20),
              Row(
                children: [
                  _StatCard(
                      value: '$score',
                      label: 'Correct',
                      color: kCorrect,
                      icon: Icons.check_rounded),
                  const SizedBox(width: 10),
                  _StatCard(
                      value: '${total - score}',
                      label: 'Wrong',
                      color: kWrong,
                      icon: Icons.close_rounded),
                  const SizedBox(width: 10),
                  _StatCard(
                      value: '${(pct * 100).round()}%',
                      label: 'Score',
                      color: kPrimary,
                      icon: Icons.percent_rounded),
                ],
              ),
              const SizedBox(height: 28),
              Text('Answer Review',
                  style: Theme.of(context).textTheme.titleLarge),
              const SizedBox(height: 14),
              ...List.generate(
                kQuestions.length,
                    (i) => _ReviewRow(
                  number:     i + 1,
                  question:   kQuestions[i],
                  userAnswer: answers[i],
                  correct:
                  answers[i] == kQuestions[i].answerIndex,
                ),
              ),
              const SizedBox(height: 28),
              _PrimaryButton(
                label: 'Try Again',
                icon:  Icons.refresh_rounded,
                onPressed: () => Navigator.pushAndRemoveUntil(
                  context,
                  _slideRoute(const QuizScreen()),
                      (r) => r.isFirst,
                ),
              ),
              const SizedBox(height: 10),
              Center(
                child: TextButton(
                  onPressed: () =>
                      Navigator.popUntil(context, (r) => r.isFirst),
                  child: const Text('Back to Home',
                      style: TextStyle(color: kMuted, fontSize: 14)),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}


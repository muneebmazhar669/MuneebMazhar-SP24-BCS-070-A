// ════════════════════════════════════════════════════════════
//  QUIZ SCREEN  (with per-question countdown timer)
// ════════════════════════════════════════════════════════════
class QuizScreen extends StatefulWidget {
  const QuizScreen({super.key});

  @override
  State<QuizScreen> createState() => _QuizScreenState();
}

class _QuizScreenState extends State<QuizScreen>
    with SingleTickerProviderStateMixin {
  final List<int?> _answers = List.filled(kQuestions.length, null);

  int  _idx      = 0;
  int? _selected;
  bool _revealed = false;
  bool _showExp  = false;

  // ── timer state ────────────────────────────────────────────
  late int   _secondsLeft;
  Timer?     _timer;
  bool       _timedOut = false; // true when this question expired

  // ── fade animation ─────────────────────────────────────────
  late final AnimationController _fadeCtrl;
  late final Animation<double>   _fadeAnim;

  @override
  void initState() {
    super.initState();
    _fadeCtrl = AnimationController(
      vsync: this,
      duration: const Duration(milliseconds: 280),
    )..forward();
    _fadeAnim =
        CurvedAnimation(parent: _fadeCtrl, curve: Curves.easeOut);
    _startTimer();
  }

  @override
  void dispose() {
    _timer?.cancel();
    _fadeCtrl.dispose();
    super.dispose();
  }

  // ── timer helpers ──────────────────────────────────────────
  void _startTimer() {
    _secondsLeft = kQuestionSeconds;
    _timedOut    = false;
    _timer?.cancel();
    _timer = Timer.periodic(const Duration(seconds: 1), _onTick);
  }

  void _stopTimer() {
    _timer?.cancel();
    _timer = null;
  }

  void _onTick(Timer t) {
    if (!mounted) { t.cancel(); return; }
    setState(() => _secondsLeft--);

    if (_secondsLeft <= 0) {
      t.cancel();
      _handleTimeout();
    }
  }

  /// Called when the clock hits zero.
  void _handleTimeout() {
    if (_revealed) return; // already answered — ignore
    setState(() {
      _timedOut  = true;
      _revealed  = true;
      // Don't set _selected — user picked nothing
      _answers[_idx] = null; // mark as unanswered / wrong
    });
    _showTimeoutBanner();
  }

  /// Shows an overlay banner for 1.8 s, then advances automatically.
  void _showTimeoutBanner() {
    showDialog(
      context: context,
      barrierDismissible: false,
      barrierColor: Colors.black45,
      builder: (_) => const _TimeoutDialog(),
    );

    Future.delayed(const Duration(milliseconds: 1800), () {
      if (!mounted) return;
      Navigator.of(context, rootNavigator: true).pop(); // close dialog
      _advance();
    });
  }

  // ── quiz logic ─────────────────────────────────────────────
  QuizQuestion get _q     => kQuestions[_idx];
  bool get _isLast        => _idx == kQuestions.length - 1;
  int  get _liveScore     => _answers
      .asMap()
      .entries
      .where((e) => e.value == kQuestions[e.key].answerIndex)
      .length;

  void _pick(int i) {
    if (_revealed) return;
    _stopTimer();
    setState(() {
      _selected  = i;
      _revealed  = true;
      _answers[_idx] = i;
    });
  }

  void _advance() {
    _stopTimer();
    if (!_isLast) {
      setState(() {
        _idx++;
        _selected = null;
        _revealed = false;
        _showExp  = false;
        _timedOut = false;
      });
      _fadeCtrl..reset()..forward();
      _startTimer();
    } else {
      Navigator.pushReplacement(
        context,
        _slideRoute(ResultScreen(answers: List.unmodifiable(_answers))),
      );
    }
  }

  _OptionState _stateOf(int i) {
    if (!_revealed) {
      return _selected == i ? _OptionState.selected : _OptionState.idle;
    }
    if (i == _q.answerIndex) return _OptionState.correct;
    if (i == _selected)      return _OptionState.wrong;
    return _OptionState.idle;
  }

  // ── colours for the timer ring ─────────────────────────────
  Color get _timerColor {
    final ratio = _secondsLeft / kQuestionSeconds;
    if (ratio > 0.5) return kCorrect;
    if (ratio > 0.25) return kAccent;
    return kTimerLow;
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: SafeArea(
        child: Column(
          children: [
            // ── progress header ──────────────────────────────
            _QuizHeader(
              current:  _idx + 1,
              total:    kQuestions.length,
              score:    _liveScore,
              progress: (_idx + 1) / kQuestions.length,
            ),

            // ── timer bar ────────────────────────────────────
            _TimerBar(
              secondsLeft: _secondsLeft,
              totalSeconds: kQuestionSeconds,
              color: _timerColor,
              revealed: _revealed,
            ),

            // ── scrollable question body ─────────────────────
            Expanded(
              child: FadeTransition(
                opacity: _fadeAnim,
                child: SingleChildScrollView(
                  padding:
                  const EdgeInsets.symmetric(horizontal: kPad),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      const SizedBox(height: 20),
                      _TagChip(label: _q.category.toUpperCase()),
                      const SizedBox(height: 14),
                      _QuestionCard(text: _q.question),
                      const SizedBox(height: 20),

                      // answer options
                      ...List.generate(
                        _q.options.length,
                            (i) => _OptionTile(
                          letter: String.fromCharCode(65 + i),
                          text:   _q.options[i],
                          state:  _stateOf(i),
                          onTap:  () => _pick(i),
                        ),
                      ),

                      // explanation panel
                      if (_revealed && !_timedOut) ...[
                        const SizedBox(height: 16),
                        _ExplanationPanel(
                          correct:  _selected == _q.answerIndex,
                          text:     _q.explanation,
                          show:     _showExp,
                          onToggle: () =>
                              setState(() => _showExp = !_showExp),
                        ),
                      ],

                      // timed-out explanation (always expanded)
                      if (_timedOut) ...[
                        const SizedBox(height: 16),
                        _ExplanationPanel(
                          correct:  false,
                          text:     _q.explanation,
                          show:     true,
                          onToggle: () {},
                        ),
                      ],

                      const SizedBox(height: 32),
                    ],
                  ),
                ),
              ),
            ),

            // ── next button bar ──────────────────────────────
            _BottomBar(
              enabled: _revealed,
              label:   _isLast ? 'See Results' : 'Next Question',
              onTap:   _advance,
            ),
          ],
        ),
      ),
    );
  }
}

// ════════════════════════════════════════════════════════════
//  TIMER BAR WIDGET
// ════════════════════════════════════════════════════════════
class _TimerBar extends StatelessWidget {
  final int    secondsLeft;
  final int    totalSeconds;
  final Color  color;
  final bool   revealed;

  const _TimerBar({
    required this.secondsLeft,
    required this.totalSeconds,
    required this.color,
    required this.revealed,
  });

  @override
  Widget build(BuildContext context) {
    final double ratio =
    (secondsLeft / totalSeconds).clamp(0.0, 1.0);

    return Container(
      padding: const EdgeInsets.symmetric(horizontal: kPad, vertical: 8),
      color: kBg,
      child: Row(
        children: [
          // countdown circle
          AnimatedContainer(
            duration: const Duration(milliseconds: 300),
            width: 36,
            height: 36,
            decoration: BoxDecoration(
              shape: BoxShape.circle,
              color: color.withOpacity(0.12),
              border: Border.all(color: color, width: 2),
            ),
            child: Center(
              child: Text(
                '$secondsLeft',
                style: TextStyle(
                  fontSize: 13,
                  fontWeight: FontWeight.w800,
                  color: color,
                ),
              ),
            ),
          ),
          const SizedBox(width: 10),
          // progress bar
          Expanded(
            child: ClipRRect(
              borderRadius: BorderRadius.circular(4),
              child: AnimatedContainer(
                duration: const Duration(milliseconds: 300),
                height: 6,
                child: LinearProgressIndicator(
                  value: ratio,
                  backgroundColor: kBorder,
                  valueColor: AlwaysStoppedAnimation<Color>(color),
                ),
              ),
            ),
          ),
          const SizedBox(width: 10),
          Text(
            revealed ? 'Done' : '${kQuestionSeconds}s',
            style: TextStyle(
              fontSize: 11,
              fontWeight: FontWeight.w700,
              color: revealed ? kMuted : color,
            ),
          ),
        ],
      ),
    );
  }
}

